<div class="my-5">
    <h1 class="text-center">학생관리</h1>
    <div class="text-end mb-2">
        <a href="" class="btn btn-primary px-5">학생등록</a>
    </div>
    <table id="tbl" class="table table-striped table-hover mt-5"></table>
    <script id="temp_students" type="text/x-handlebars-template">
        <tbody>
            {{#each .}}
            <tr>
                <td>{{SCODE}}</td>
                <td>{{SNAME}}</td>
                <td>{{DEPT}}</td>
                <td>{{FDATE}}</td>
                <td>{{PNAME}}</td>
                <td class="text-end"><button class="btn btn-outline-danger btn-sm delete" scode="{{SCODE}}">삭제</button></td>
            </tr>
            {{/each}}
        </tbody>
    </script>
</div>

<script>
    getList();
    function getList(){
        $.ajax({
            type:"get",
            url:"/haksa/stu/list.json",
            success:function(data){
                console.log(data);
                const temp = Handlebars.compile($("#temp_students").html());
                $("#tbl").html(temp(data));
            }
        });
    }
</script>