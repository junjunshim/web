<div class="my-5">
    <h1 class="text-center">교수관리</h1>
    <div class="text-end mb-3">
        <a href="/haksa/pro/insert" class="btn btn-primary px-5">교수등록</a>
    </div>
    <table id="tbl" class="table table-striped table-hover mt-5"></table>
    <script id="temp" type="text/x-handlebars-template">
        <tbody>
            {{#each .}}
            <tr>
                <td>{{PCODE}}</td>
                <td>{{PNAME}}</td>
                <td>{{DEPT}}</td>
                <td>{{FDATE}}</td>
                <td>{{TITLE}}</td>
                <td>{{FSALARY}}</td>
                <td><button pcode="{{PCODE}}" class="btn btn-outline-danger btn-sm delete">delete</button></td>
            </tr>
            {{/each}}
        </tbody>
    </script>
</div>
<script>
    $("#tbl").on("click", ".delete", function(){
        const pcode = $(this).attr("pcode");
        if(confirm(`${pcode}번 교수를 삭제하시겠습니까?`)){
            $.ajax({
                type: "post",
                url: "/haksa/pro/delete",
                data: {pcode},
                success:function(){
                    alert(`${pcode}번 교수를 삭제했습니다.`);
                    location.href="/haksa/pro";
                },
                error: function(){
                    alert(`${pcode}번 교수 삭제에 실패했습니다.`);
                }
            })
        }
    });
    
    function getList(){
        $.ajax({
            type: "get",
            url: "/haksa/pro/list.json",
            success: function(data){
                console.log(data);
                const temp=Handlebars.compile($("#temp").html());
                $("#tbl").html(temp(data));
            }
        });
    }

    getList();
</script>